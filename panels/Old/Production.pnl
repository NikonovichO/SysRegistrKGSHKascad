"main(mapping event)
{
  int rc, yr, mn, d, hh, mm, ss;
  dbConnection conn;
  dbCommand cmd;
  dbRecordset rs;
  anytype fld;
  dyn_string models;
  string cmdStr, sn, id_r, tstart, s_yr, s_mn, s_d, s_hh, s_mm, s_ss, s_t, press;

  rc = dbOpenConnection(\"Data Source=KGSHVulcanisation;UID=BTW\\nikonovichoa\", conn);
  Debug(\"подключение:\", rc);

  if (!rc)
  {
    rc=-1;
  //получаем id модели
  cmdStr = \"SELECT id_tire, model_tire FROM tModelsTire WHERE model_tire = '\" + CB_Model.text+\"'\";
  DebugN(\"модель:\", cmdStr);
  rc =  dbOpenRecordset(conn, cmdStr, rs);
  DebugN(\"модель запрос:\",rc);


  if (!rc)
  {
     dbGetField(rs, 0, idModel);
     Debug(\"idModel:\", idModel);
  }
  rc= -1;
  cmdStr = \"SELECT id_recipe, num_recipe FROM tRecipes WHERE num_recipe = '\" + CB_Recipe.text + \"'\";
  DebugN(\"рецепт:\", cmdStr);
  rc =  dbOpenRecordset(conn, cmdStr, rs);
  if (!rc)
  {
     dbGetField(rs, 0, idRecipe);
     Debug(\"idRecipe:\", idRecipe);
  }
   dbCloseConnection(conn);

    time t = getCurrentTime();
    yr = year(t);
    mn = month(t);
    d = day(t);
    hh = hour(t);
    mm = minute(t);
    ss = second(t);
    // переводим дату в строковый литерал для добавления в БД
    s_yr = yr;
    if (mn < 9) s_mn = \"0\" + mn;
       else  s_mn = mn;
    if (d < 9) s_d = \"0\" + d;
       else  s_d = d;
    if (hh < 9) s_hh = \"0\" + hh;
       else  s_hh = hh;
    if (mm < 9) s_mm = \"0\" + mm;
       else  s_mm = mm;
    if (ss < 9) s_ss = \"0\" + ss;
       else  s_ss = ss;
    s_t = s_yr+ '-' + s_mn + '-' + s_d + ' ' + s_hh + ':' + s_mm + ':' +s_ss;
    Debug(\"time:\", s_t);
    rc = dbOpenConnection(\"Data Source=KGSHVulcanisation;UID=BTW\\nikonovichoa\", conn);
    Debug(\"подключение_1:\", rc);
    rc = dbBeginTransaction(conn); //запуск транзакции
    cmdStr = \"INSERT INTO tPassport(serial_num, id_recipe, time_start, id_press, id_tire, raw_tire_num) values (?,?,?,?,?,?)\";
    // id_recipe,
    rc = dbStartCommand(conn, cmdStr, cmd);
    Debug(\"StartCommand:\", rc);
    if (!rc)
    {
      getValue(\"CB_Press\", \"text\", press);
     rc = dbSetParameter(cmd, 1, DB_PARAM_IN, TF_Number.text);
      rc = dbSetParameter(cmd, 2, DB_PARAM_IN, idRecipe);
      rc = dbSetParameter(cmd, 3, DB_PARAM_IN, s_t);
      rc = dbSetParameter(cmd, 4, DB_PARAM_IN, press);
      rc = dbSetParameter(cmd, 5, DB_PARAM_IN,  idModel);
      rc = dbSetParameter(cmd, 6, DB_PARAM_IN, TF_NumRow.text);

      rc = dbExecuteCommand(cmd);
      Debug(\"dbExecuteCommand:\", rc);
      rc = dbFinishCommand(cmd);
      Debug(\"dbFinishCommand:\", rc);
    }
    if (!rc)
    {
      rc = dbCommitTransaction(conn); // Внесены изменения в БД
      Debug(\"DbCommitTransaction:\", rc);
    }
     else
    {
       rc = dbRollbackTransaction (conn); // Изменения в БД отклонены
       Debug(\"dbRollbackTransaction:\", rc);
     //  ChildPanelOnRelativModal(\"InformationPnl.pnl\", \"Information\",  makeDynString(\"\"),10,10);
     }
    //ChildPanelOnRelativModal(\"InformationPnl.pnl\", \"Information\",  makeDynString(\"\"),10,10);
   }

  dbCloseConnection(conn); // Соединение закрыто
}" 0
