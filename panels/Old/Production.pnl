"main()
{
  int rc;
  dbConnection conn;
  dbRecordset rs;
  string cmdStr, sn, id_r, tstart;
  //подключение к БД через ODBC. В приложении \"Администратор ODBC\" создается источник данных, в нашем случае KGSHVulcanisation
  rc = dbOpenConnection(\"Data Source=KGSHVulcanisation;UID=BTW\\nikonovichoa\", conn);
  Debug(\"подключение:\", rc);
  if (!rc)
  {
    //выборка данных в recordset
    cmdStr = \" SELECT num_recipe FROM tRecipes \";
    rc =  dbOpenRecordset(conn, cmdStr, rs);
    Debug(\"dbOpenRecordset\", rc);

    if (!rc)
    {
     shape list = getShape(\"CB_Recipe\");
     while (!rc && !dbEOF (rs))
      {
       dbGetField(rs, 0, sn);
       //rc = dbSetParameter(cmd, 1, DB_PARAM_IN, 1111);
       list.appendItem(sn); // Добавление
       dbMoveNext(rs);
      }
     }
     //выборка данных в recordset
    cmdStr = \"SELECT id_press FROM tPresses\";
    rc =  dbOpenRecordset(conn, cmdStr, rs);
   if (!rc)
    {
     shape list = getShape(\"CB_Press\");
     while (!rc && !dbEOF (rs))
      {
       dbGetField(rs, 0, sn);
       //rc = dbSetParameter(cmd, 1, DB_PARAM_IN, 1111);
       list.appendItem(sn); // Добавление
       dbMoveNext(rs);
      }
     }
     cmdStr = \"SELECT model_tire FROM tModelsTire\";
    rc =  dbOpenRecordset(conn, cmdStr, rs);
   if (!rc)
    {
     shape list = getShape(\"CB_Model\");
     while (!rc && !dbEOF (rs))
      {
       dbGetField(rs, 0, sn);
       //rc = dbSetParameter(cmd, 1, DB_PARAM_IN, 1111);
       list.appendItem(sn); // Добавление
       dbMoveNext(rs);
      }
     }
  }

    rc = dbCloseConnection(conn); // Соединение закрыто
  }
