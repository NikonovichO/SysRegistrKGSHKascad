"// SimpleCtrlScriptStart {invalid}
main()
{
  EP_childPanelOn();
}

void EP_childPanelOn()
{
  int nLine, nColl;
  string SN;
  getValue (\"tblPassports\", \"currentCell\", nLine, nColl);
  Debug(\"line:\",nLine);
  getValue (\"tblPassports\", \"cellValueRC\", nLine, \"serial_num\", SN);
  Debug(\"num:\",SN);
  ChildPanelOnCentralModal(\"Old/Passport.pnl\", \"Passport\",  makeDynString(\"$dp:\" + SN));
}

