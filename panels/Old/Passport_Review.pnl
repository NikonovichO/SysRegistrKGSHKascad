LANG:10027 48 показать список паспортов
"main(mapping event)
{
  int rc;
  dbConnection conn;
  dbCommand cmd;
  dbRecordset rs;
  anytype fld;
  dyn_string models;
  string cmdStr, sn, raw, model, recipe, quality, num_diaphr, cycle_counter, all_cycles, line, press;
  time  time_start,  time_end, time_forming;
  string startStr, endStr;
  bool bad_quality;

  tblPassports.deleteAllLines();

  //подключение к БД через ODBC. В приложении \"Администратор ODBC\" создается источник данных, в нашем случае KGSHVulcanisation
  rc = dbOpenConnection(conStr, conn);
  Debug(\"подключение:\", rc);

  if (!rc)
  {
    bool isPeriodChecked;
    getValue(\"chbPeriod\", \"state\", 0, isPeriodChecked);
    // Считываем значения из виджетов DateTimeEdit
    getValue(\"DE_START\", \"dateTime\",time_start);
    getValue(\"DE_END\", \"dateTime\", time_end);

    //Форматируем время в строку для MS SQL (YYYY-MM-DD HH:MM:SS)
     startStr = formatTime(\"%Y-%m-%d %H:%M:%S\", time_start);
     endStr   = formatTime(\"%Y-%m-%d %H:%M:%S\", time_end);

     cmdStr = \"SELECT serial_num, raw_tire_num, model_tire, id_recipe, bad_quality, CAST(time_start AS datetime) AS time_start, CAST(time_stop AS datetime) AS time_stop, press_fullNum, num_diaphr, count_diaphr, limit_diaphr,\"+
              +\" CAST(time_form_start AS datetime) AS time_form_start FROM vPassport\";

     if (isPeriodChecked) //выборка данных в recordset по дате
   {
     cmdStr =  cmdStr + \" WHERE time_start BETWEEN '\"+startStr+\"' AND '\"+ endStr+\"'\";
    }
    bool isPressChecked;
    getValue(\"chbPress\", \"state\", 0, isPressChecked);

  //выборка по прессу
   if(isPressChecked && !isPeriodChecked)
   {
     getValue(\"cbLine\", \"selectedText\", line);
     getValue(\"cbPress\", \"selectedText\", press);
     cmdStr = cmdStr  + \" WHERE press_fullNum = \" + line + press;
   }

    //выборка по прессу и периоду
    if(isPressChecked && isPeriodChecked)
   {
     getValue(\"cbLine\", \"selectedText\", line);
     getValue(\"cbPress\", \"selectedText\", press);
     cmdStr = cmdStr + \" AND press_fullNum = \" + line + press;
   }

  //Выборка по  серийному номеру без учета даты
    bool isSNChecked;
    getValue(\"chBox_SN\", \"state\", 0, isSNChecked);
  //  Debug(\"isSNChecked:\", isSNChecked);

  if(isSNChecked && !isPeriodChecked)
   {
     cmdStr = cmdStr + \" WHERE serial_num like '%\" +tfSerialNum.text+\"%'\";
    }

  //Серийный номер и период
    bool isQuality;
    getValue(\"chBox_quality\", \"state\", 0, isQuality);
    if(isQuality && isPeriodChecked)
    {
     cmdStr = cmdStr + \"AND bad_quality  = true\";;
    }
    rc = dbOpenRecordset(conn, cmdStr, rs);

    Debug(\"rs:\", rc);
    Debug(\"cmdStr:\", cmdStr);

    if (!rc)
    {
    // shape list = getShape(\"CB_Passports\");
     while (!rc && !dbEOF (rs))
     {
       dbGetField(rs, 0, sn);
       dbGetField(rs, 1, raw);
       dbGetField(rs, 2, model);
       dbGetField(rs, 3, recipe);
       dbGetField(rs, 4, bad_quality);
       dbGetField(rs, 5, time_start);
       dbGetField(rs, 6, time_end);
       dbGetField(rs, 7, press);
       dbGetField(rs, 8, num_diaphr);
       dbGetField(rs, 9, cycle_counter);
       dbGetField(rs, 10, all_cycles);
       dbGetField(rs, 11, time_forming);

      // dbGetField(rs, 8,  num_diaphr);
      // dbGetField(rs, 9, cycle_counter);
      // dbGetField(rs, 10, all_cycles);
       tblPassports.appendLine(\"serial_num\", sn, \"raw\", raw, \"model\", model, \"recipe\", recipe, \"time_forming\", time_forming,
                               \"time_start\", time_start, \"time_end\", time_end,\"press\", press, \"num_diaphr\", num_diaphr, \"cycle_counter\", cycle_counter, \"all_cycles\", all_cycles);
       dbMoveNext(rs);
      }
     }
     dbCloseConnection(conn); // Соединение закрыто
  }

    //переводим таблицу в режим выделения записи
    tblPassports.tableMode(TABLE_SELECT_BROWSE);
    setValue (\"tblPassports\", \"selectByClick\", 1);
}" 0
