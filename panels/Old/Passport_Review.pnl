"main()
{
   int rc;
  dbRecordset rs;
  dyn_string models;
  string cmdStr, nLine, nPress;
  dbConnection conn;

  cbPress.deleteAllItems();
  rc = dbOpenConnection(conStr, conn);
  Debug(\"подключение2:\", rc);
  Debug(\"строка подключения2:\", conStr);
  getValue(\"cbLine\", \"text\",  nLine);

  if (!rc)
  {
    cmdStr = \"SELECT number FROM tPresses WHERE line = \"+nLine;
    rc =  dbOpenRecordset(conn, cmdStr, rs);
    Debug(\"dbOpenRecordset\", rc);
    if (!rc)
    {
     shape list = getShape(\"cbPress\");
     while (!rc && !dbEOF (rs))
     {
       dbGetField(rs, 0, nPress);
       list.appendItem(nPress); // Добавление
       dbMoveNext(rs);
      }
     }
   }
  dbCloseConnection(conn); // Соединение закрыто
}" 0

