LANG:10027 8 Passport
PANEL,-1 -1 1856 865 N {207,207,207} 1
"$dp"
"main()
{
  string SN = $dp;
  PassportSelect(SN);
}

 void PassportSelect(string serialNum)
{
  int rc;
  dbConnection conn;
  dbCommand cmd;
  dbRecordset rs;
  anytype fld;
  dyn_string models;
  int press_num, num_diaphr, count_diaphr, limit_diaphr;
  string cmdStr, id_r, sn, press_line, num_recipe, raw_tire, model_tire, dp_press, time_str1, time_str2,  time_str3, size_diaphr;
  time timestart, timestop, time_forming;
  bool bad_quality;

  //подключение к БД через ODBC. В приложении \"Администратор ODBC\" создается источник данных, в нашем случае KGSHVulcanisation
  //rc = dbCloseConnection(\"Data Source=KGSHVulcanisation;UID=BTW\\nikonovichoa\", conn);
  dpGet(\"System1:GlobalVar1.ConnectionDB:_online.._value\",conStr);
  rc = dbOpenConnection(conStr, conn);
  Debug(\"подключение:\", rc);
  shape list = getShape(\"CB_Passports\");

  if (!rc)
  {
    //выборка данных в recordset
    cmdStr = \"SELECT serial_num, CAST(time_start AS datetime) AS time_start,  CAST(time_stop AS datetime) AS time_stop, \" +
              + \"raw_tire_num, press_line, press_number, id_recipe, model_tire, size_diaphr, num_diaphr, count_diaphr, limit_diaphr, CAST(time_form_start AS datetime) AS time_form_start, bad_quality FROM vPassport WHERE serial_num = '\" + serialNum+\"'\";
    rc =  dbOpenRecordset(conn, cmdStr, rs);
    Debug(\"cmdStr\", cmdStr);
    Debug(\"dbOpenRecordset\", rc);

   if (!rc)
   {
    shape num = getShape(\"TF_NUMBER\");
    shape model = getShape(\"TF_MODEL\");
    shape recipe = getShape(\"TF_PRESS\");
    shape press = getShape(\"TF_RECIPE\");
    shape num_row = getShape(\"TF_ROWTIRE\");

    dbGetField(rs, 0, sn);
    dbGetField(rs, 1, timestart);
    dbGetField(rs, 2, timestop);
    dbGetField(rs, 3, raw_tire);
    dbGetField(rs, 4, press_line);
    dbGetField(rs, 5, press_num);
    dbGetField(rs, 6, num_recipe);
    dbGetField(rs, 7, model_tire);
    dbGetField(rs, 8, size_diaphr);
    dbGetField(rs, 9, num_diaphr);
    dbGetField(rs, 10, count_diaphr);
    dbGetField(rs, 11, limit_diaphr);
    dbGetField(rs, 12, time_forming);
    dbGetField(rs, 13, bad_quality);
    Debug(\"time_forming\", time_forming);

   // Debug(\"time_stop\",  timestop);

  //  setValue(\"TREND1\", \"timeInterval\", timestop-timestart);
  //  setValue(\"TREND1\", \"timeBegin\", timestart);
    setValue(\"TREND2\", \"timeInterval\", timestop-timestart);
    setValue(\"TREND2\", \"timeBegin\", timestart);
   // setValue(\"TREND1\", \"timeBegin\", 1, time_forming);
    setValue(\"TREND1\", \"visibleTimeRange\", 0, time_forming,timestart);
    setValue(\"TREND1\", \"visibleTimeRange\", 1, timestart,timestop);
    setValue(\"TREND1\", \"visibleTimeRange\", 2, timestart,timestop);

    time_str1 = formatTime(\"%d-%m-%Y %H:%M:%S\", timestart);
    time_str2 = formatTime(\"%d-%m-%Y %H:%M:%S\", timestop);
    time_str3 = formatTime(\"%d-%m-%Y %H:%M:%S\", time_forming);

    setValue(\"TF_NUMBER\", \"text\", sn);
    setValue(\"TF_MODEL\", \"text\", model_tire);
    setValue(\"TF_PRESS\", \"text\", press_line+\"/\"+press_num);
    setValue(\"TF_RECIPE\", \"text\",  num_recipe);
    setValue(\"TF_ROWTIRE\", \"text\",  raw_tire);
    setValue(\"TF_TimeStart\", \"text\", time_str1);
    setValue(\"TF_TimeStop\", \"text\", time_str2);
    setValue(\"TF_SizeDiaphr\", \"text\", size_diaphr);
    setValue(\"TF_NumberDiaph\", \"text\", num_diaphr);
    setValue(\"TF_Count\", \"text\", count_diaphr);
    setValue(\"TF_Limmit\", \"text\", limit_diaphr);
    setValue(\"TF_TimeForming\", \"text\", time_str3);
    if (bad_quality)
    {
     setValue(\"TF_QUALITY\", \"text\", \"с отклонениями\");
    }
    else
    {
    setValue(\"TF_QUALITY\", \"text\", \"норма\");
    }


    DebugN(\"press_num\", press_num);
    DebugN(\"time_start\",  timestart);
    Debug(\"time_stop\",  timestop);

   //определяем точку данных по номеру пресса
    switch(press_num)
  {
    case 1: dp_press = \"Press1.\"; break;
    case 2: dp_press = \"Press2.\"; break;
    case 3: dp_press = \"Press3.\"; break;
    case 4: dp_press = \"Press4.\"; break;
  }
    DebugN(\"dp:\", dp_press);

   TREND1.connectDirectly(\"FormingPressuer\", \"System1:\"+dp_press+\"Inputs.AnalogValues.PressSupplyDiaph:_online.._value\");
   TREND1.connectDirectly(\"PressReturnDiaph\", \"System1:\"+dp_press+\"Inputs.AnalogValues.PressReturnDiaph:_online.._value\");
   TREND1.connectDirectly(\"PressSupplyDiaph\", \"System1:\"+dp_press+\"Inputs.AnalogValues.PressSupplyDiaph:_online.._value\");
   TREND1.connectDirectly(\"TempSupplyDiaph\", \"System1:\"+dp_press+\"Inputs.AnalogValues.TempSupplyDiaph:_online.._value\");
   TREND1.connectDirectly(\"TempReturnDiaph\", \"System1:\"+dp_press+\"Inputs.AnalogValues.TempReturnDiaph:_online.._value\");

   TREND2.connectDirectly(\"PressureCam\", \"System1:\"+dp_press+\"Inputs.AnalogValues.PressureCam:_online.._value\"); //линия 1
   //TREND2.connectDirectly(\"TempCam\",\" System1:\"+dp_press+\"Inputs.AnalogValues.TempCam:_online.._value\");//линия 2
  TREND2.connectDirectly(\"TempCam\", \"System1:\"+dp_press+\"Inputs.AnalogValues.TempCam:_online.._value\");
  TREND2.manageCommands(TRUE);
   //TREND1.connectDirectly(\"PressingForce\", \"System1:\"+dp_press+\"Inputs.AnalogValues.PressingForce:_online.._value\"); //линия 3
  }

  }
    dbCloseConnection(conn); // Соединение закрыто


