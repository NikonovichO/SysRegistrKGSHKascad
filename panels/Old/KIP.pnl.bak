"main()
{
//определяем массивы  для заполнения строк таблицы TABLE2
  dyn_anytype pc, cn;

  pc[1]=\"Давление, Мпа\";
  pc[2]= \"\";
  pc[3]=\"red\";

  cn[1]= \"Управление, %\";
  cn[2]= \"\";
  cn[3]=\"blue\";

  //заполняем строки таблицы, используя массив
  setValue(\"TABLE2\", \"updateLine\", 1, \"Param\", pc, \"Value\", pc, \"TimeStemp\", pc);
  setValue(\"TABLE2\", \"updateLine\", 1, \"Param\", cn, \"Value\", cn, \"TimeStemp\", cn);

//связываем метод FillTable с DPE точки данных
  dpConnect(\"FillTable2\",\"System1:\"+$dp+\"Inputs.AnalogValues.TempCam\",
                        \"System1:\"+$dp+\"Inputs.AnalogValues.PressureCam\");
}

void FillTable2(string dpe1, float val1, string dpe2, float val2)
{
 shape table = getShape(\"TABLE2\");
 time ts1,ts2;

//записываем в поле Value переменную val1, в ту строку где поле \"Param\" = \"Давление подачи, Мпа\", 1 - число полей по которым производится поиск строки
  table.updateLine(1, \"Param\", \"Давление, Мпа\", val1);
  table.updateLine(1, \"Param\", \"Управление, %\", val2);

//получаем время текущего значения
  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.PressSupplyDiaph:_online.._stime\", ts1);
  table.updateLine(1, \"Param\", \"Температура,°С\", \"TimeStemp\", ts1);

  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.PressSupplyDiaph:_online.._stime\", ts2);
  table.updateLine(1, \"Param\", \"Давление, Мпа\", \"TimeStemp\", ts2);

  }
