"main()
{
//определяем массивы  для заполнения строк таблицы TABLE2
  dyn_anytype tc,pc,fp;
  tc[1]= \"Температура,°С\";
  tc[2]= \"\";
  tc[3]=\"red\";
  pc[1]=\"Давление, Мпа\";
  pc[2]= \"\";
  pc[3]=\"blue\";
  fp[1]= \"Прессовое усилие, бар\";
  fp[2]= \"\";
  fp[3]=\"red\";

  Debug(\"tc[1]: \", tc[1]);
//заполняем строки таблицы, используя массив
  setValue(\"TABLE2\",\"updateLine\",1,\"Param\",tc,\"Value\",tc,\"TimeStemp\",tc);
  setValue(\"TABLE2\",\"updateLine\",1,\"Param\",pc,\"Value\",pc,\"TimeStemp\",pc);
  setValue(\"TABLE2\",\"updateLine\",1,\"Param\",fp,\"Value\",fp,\"TimeStemp\",fp);

//связываем метод FillTable с DPE точки данных
  dpConnect(\"FillTable2\",\"System1:\"+$dp+\"Inputs.AnalogValues.TempCam\",
                        \"System1:\"+$dp+\"Inputs.AnalogValues.PressureCam\",
                        \"System1:\"+$dp+\"Inputs.AnalogValues.PressingForce\");
}

void FillTable2(string dpe1, float val1, string dpe2, float val2, string dpe3, float val3)
{
 shape table = getShape(\"TABLE2\");
 time ts1,ts2,ts3;

//записываем в поле Value переменную val1, в ту строку где поле \"Param\" = \"Давление подачи, Мпа\", 1 - число полей по которым производится поиск строки
  table.updateLine(1,\"Param\",\"Температура,°С\",\"Value\",val1);
  table.updateLine(1,\"Param\",\"Давление, Мпа\",\"Value\",val2);
  table.updateLine(1,\"Param\",\"Прессовое усилие, бар\",\"Value\",val3);

//получаем время текущего значения
  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.TempCam:_online.._stime\", ts1);
  table.updateLine(1, \"Param\", \"Температура,°С\", \"TimeStemp\", ts1);

  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.PressureCam:_online.._stime\", ts2);
  table.updateLine(1, \"Param\", \"Давление, Мпа\", \"TimeStemp\", ts2);

  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.PressingForce:_online.._stime\", ts3);
  table.updateLine(1, \"Param\", \"Прессовое усилие, бар\", \"TimeStemp\", ts3);
}
