void EP_textFieldIn()
{
  dyn_errClass err;

  if( !dpExists( \"System1:\"+$dp+\"Inputs.StringValues.Recipe:_online.._value\"))
  {
    setValue(\"\", \"color\", \"_dpdoesnotexist\");
    return;
