"main(mapping event)
{
  time t = getCurrentTime();
  setValue(\"TREND1\", \"timeBegin\", t);
  bool val;
  dpGet(\"System1:\"+$dp+\"Inputs.BoolValues.Runtime\",val);
  if (val)
  {
     dpSet(\"System1:\"+$dp+\"Inputs.BoolValues.Runtime\",0);
     Debug(\"0\");

   }
  else
   {
     dpSet(\"System1:\"+$dp+\"Inputs.BoolValues.Runtime\",1);
     DebugN(\"1\");
     setValue(\"TREND1\", \"timeBegin\", t);
   }
}
