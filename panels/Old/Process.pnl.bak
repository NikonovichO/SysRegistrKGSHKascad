void EP_textFieldIn()
{
  dyn_errClass err;

  if( !dpExists( \"System1:\"+$dp+\"Inputs.StringValues.Model:_online.._value\"))
  {
    setValue(\"\", \"color\", \"_dpdoesnotexist\");
    return;
  }

  dpConnect(\"EP_textFieldInCB\",
            \"System1:\"+$dp+\"Inputs.StringValues.Model:_online.._value\");
  err = getLastError();
  if (dynlen(err) > 0)
    setValue(\"\", \"color\", \"_dpdoesnotexist\");

}


void EP_textFieldInCB(string dp, string sNewValue)
{
  setValue(\"\", \"text\", dpValToString(dp, sNewValue, FALSE) );
  Debug(\"точка данных: \",dp);
}

