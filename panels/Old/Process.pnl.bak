"main(mapping event)
{
  int yr,ms,dd,hh,mn;
  time t = getCurrentTime();
  yr = year(t);
  ms = month(t);
  dd = day(t);
  hh = hour(t);
  mn = minute(t);
  mn = mn-10;
  t = makeTime(yr,ms,dd,hh,mn);
  setValue(\"TREND1\", \"timeBegin\", t);
  setValue(\"TREND2\", \"timeBegin\", t);
}
