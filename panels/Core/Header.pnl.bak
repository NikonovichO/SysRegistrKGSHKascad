""0  1
E "shape current_btn;  //нажатая кнопка

void check_btn(shape new_btn){  // меняем состояние нажатой кнопки и предыдущей кнопки
  if (shapeExists(current_btn)) {
    current_btn.enabled(true);
    current_btn.backCol(\"{0,136,185}\");
  }
  // Настраиваем новую кнопку
  new_btn.backCol(\"{148,236,248}\");
  new_btn.enabled(false);

  // Запоминаем её как текущую
  current_btn = new_btn;
}" 0
