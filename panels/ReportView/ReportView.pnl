LANG:10027 29 Сохранить отчет
"main(mapping event)
{
  string savePath;
  string defaultName = $sReportName + \"_\" + formatTime(\"%Y%m%d_%H%M\", getCurrentTime()) + \".pdf\";

  // Параметры: путь по умолчанию, фильтр файлов, формат
  fileSelector(savePath, \"/\", false, \"*.pdf\", \"Сохранить отчет как...\");

  //или всегда сохранять в одно и то же место?

  // Если путь выбран
  if (savePath != \"\")
  {
    /* Проверяю, есть ли расширение .pdf
    if (patternMatch(\"*.pdf\", savePath) == false) {
      savePath += \".pdf\";
    }*/

    // Копирую превью в выбранное место
    if (filecopy($sPdfPath, savePath) == 0) {
      ChildPanelOnCentral(\"Vision/MessageInfo\", \"Успех\", makeVariable(\"$1\", \"Файл успешно сохранен!\"));
      btn_PrintReport.enabled(true);
    } else {
      ChildPanelOnCentral(\"Vision/MessageInfo\", \"Ошибка\", makeVariable(\"$1\", \"Не удалось сохранить файл. Проверьте права доступа.\"));
    }
  }


}" 0
