"main()
{
  // заголовок для окна
  this.caption = \"Предпросмотр: \" + $sReportName;

  // load
  if (fileExists($sPdfPath)) { //проверяю что файл превью отчета создался
    pdfViewer.fileName($sPdfPath);
  } else {
    ChildPanelOnCentral(\"Vision/MessageInfo\", \"Ошибка\", makeVariable(\"$1\", \"Файл отчета не найден!\"));
  }
}" 0
 "terminate() {
  if (fileExists($sPdfPath)) { //удаляю превью
    remove($sPdfPath);
  }
