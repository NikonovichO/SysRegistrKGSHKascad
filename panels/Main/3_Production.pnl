"main()
{
    //Debug (\"строка подключения:\", conStr);
  int rc;
  dbRecordset rs;
  dyn_string models;
  string cmdStr, nLine;
  dbConnection conn;

  dpGet(\"System1:GlobalVar1.ConnectionDB:_online.._value\",conStr);
  rc = dbOpenConnection(conStr, conn);
  Debug(\"подключение1:\", rc);
  Debug(\"строка подключения1:\", conStr);

  if (!rc)
  {
    cmdStr = \"SELECT DISTINCT line FROM tPresses\";
    rc =  dbOpenRecordset(conn, cmdStr, rs);
    Debug(\"dbOpenRecordset\", rc);
    if (!rc)
    {
     shape list = getShape(\"cbLine\");
     while (!rc && !dbEOF (rs))
     {
       dbGetField(rs, 0, nLine);
       list.appendItem(nLine); // Добавление
       dbMoveNext(rs);
      }
     }
   }
  dbCloseConnection(conn); // Соединение закрыто
