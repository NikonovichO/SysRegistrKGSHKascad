void EP_childPanelOn()
{
  int nLine, nColl;
string SN;
getValue (\"tblPassports\", \"currentCell\", nLine, nColl);
Debug(\"line:\",nLine);
getValue (\"tblPassports\", \"cellValueRC\", nLine, \"serial_num\", SN);
Debug(\"line:\",nLine);
  ChildPanelOnCentralModal(\"Passport.pnl\", \"Passport\",  makeDynString(\"$dp:\" + SN));
}

