"main()
{
  int rc;
  dbConnection conn;
  dbRecordset rs;
  anytype fld;
  //подключение к БД через ODBC. В приложении \"Администратор ODBC\" создается источник данных, в нашем случае KGSHVulcanisation
  rc = dbOpenConnection(\"Data Source=KGSHVulcanisation;UID=BTW\\nikonovichoa\", conn);
  Debug(\"подключение для чтения:\", rc);
  //showError(conn);
  if (!rc)
  {
   //создаем и открываем набор записей
    rc = dbOpenRecordset (conn, \"SELECT model_tire FROM tTires\", rs);
    // The data subset is opened
     if (!rc)
     {
//       while (!rc && !dbEOF (rs))
      // as long as the file end is not reached
//       {
        rc = dbGetField (rs, 0, fld);
         Debug(\"dbGetField:\", rc);
        //reads current column
         if (!rc)
           TEXT_SERIALNUM.text = fld;
//         DebugN(\"Field 1: \" , fld);
//         rc = dbGetField (rs, 1, fld);
//         if (!rc)
//         DebugN(\"Field 2: \" , fld);
//         rc = dbMoveNext(rs); //to the next record
      }
      dbCloseRecordset (rs); //closes subset
    }
    dbCloseConnection (conn); //closes connection
  EMBEDDED_MODULE1.ModuleName = \"Module1\";
  dyn_string MyParams;
  MyParams =  makeDynString(\"$dp:Press2.\");
  RootPanelOnModule(\"Process.pnl\", \"1\", \"Module1\", MyParams);
  //EMBEDDED_MODULE1.loadPanel(0, \"Process.pnl\", \"Process\", MyParams);
 // EMBEDDED_MODULE1.panel(panel);
  }

void showError (dbConnection conn)
{
  int errCnt, errNo, errNative;
  string errDescr, errSql;
  int rc;
  errCnt = 1;
  rc = 0;
  while (errCnt > 0 && ! rc)
  {
    rc = dbGetError (conn, errCnt, errNo, errNative, errDescr,
    errSql);
    if (!rc)
    {
      DebugN(\"Errornumber : \", errNo);
      DebugN(\"BaseError : \", errNative);
      DebugN(\"Description : \", errDescr);
      DebugN(\"SQL-errortext: \", errSql);
    }
    else
    DebugN(\"dbGetError failed, rc = \", rc);
    errCnt--;
  }
}

void rootPanel()
{
   EMBEDDED_MODULE1.ModuleName = \"Module1\";
  dyn_string MyParams;
  MyParams =  makeDynString(\"$dp:Press1.\");
  RootPanelOnModule(\"Process.pnl\", \"1\", \"Module1\", MyParams);
  //EMBEDDED_MODULE1.loadPanel(0, \"Process.pnl\", \"Process\", MyParams);
 // EMBEDDED_MODULE1.panel(panel);
}
