"main() {
  string txt;
  string model;
  string recipe;
  string serialnum;
  string rawtirenum;

  // Получаем выбранное значение из комбобокса
  getValue(\"\", \"text\", txt);

  // Полное имя точки
  string fullDP = \"Press\" + txt;

  // Управление панелью
  dyn_string MyParams = makeDynString(\"$dp:\" + fullDP + \".\");
  RootPanelOnModule(\"Main/Process_sub/Press_Process.pnl\", \"Process\", \"Module1\", MyParams);

  // Получение имени модели
  dpGet(fullDP + \".Inputs.StringValues.Model:_online.._value\", model,
        fullDP + \".Inputs.StringValues.Recipe:_online.._value\", recipe,
        fullDP + \".Inputs.StringValues.SerialNumber:_online.._value\", serialnum,
        fullDP + \".Inputs.StringValues.RawTireNumber:_online.._value\", rawtirenum
        );

  ModelName.text = model;
  RecipeName.text = recipe;
  SerialNumber.text = serialnum;
  RawTireNumber.text = rawtirenum;
}
