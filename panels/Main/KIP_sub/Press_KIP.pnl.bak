"main(mapping event)
{

  idispatch objXL;
  idispatch objXLWorkbooks;
  idispatch objXLWorkbook;
  idispatch objXLWorksheet; // Добавили объект Worksheet
  anytype range;
  string filePath = \"D:\\\\1.xlsx\"; // Путь к вашему Excel файлу.  Обязательно укажите правильный путь!
  string sheetName = \"Sheet1\";        // Имя листа, в который нужно внести изменения.  Измените, если нужно.

  objXL = createComObject(\"Excel.Application\");

  objXL.Visible = -1; // -1 делает Excel видимым, 0 - невидимым (для фоновой работы)
  objXLWorkbooks = objXL.Workbooks;

  // Открываем СУЩЕСТВУЮЩИЙ файл
  objXLWorkbook = objXLWorkbooks.Open(filePath);
 DebugN(\"Документ открыт\");
 objXLWorksheet = objXLWorkbook.Worksheets(sheetName);  // Первый лист (индексация с 1)

 range=objXL.Range(\"A3\");
 range.Value2 = \"Привет мир\"; // Записываем значение

  // Сохраняем изменения и закрываем файл
  objXLWorkbook.Save(); // Сохраняем изменения в файле
  // objXLWorkbook.SaveAs(\"C:\\\\path\\\\to\\\\your\\\\newfile.xlsx\");  // Альтернатива: Сохранить как новый файл, не перезаписывая исходный.

  objXLWorkbook.Close();    // Закрываем книгу

  objXL.Quit();  // Закрываем Excel.  Это важно!
DebugN(\"Документ закрыт, проверьте результат\");
  // Освобождаем COM-объекты
  releaseComObject(objXLWorksheet);
  releaseComObject(objXLWorkbook);
  releaseComObject(objXLWorkbooks);
  releaseComObject(objXL);

}" 0
