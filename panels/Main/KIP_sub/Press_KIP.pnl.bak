 void ShowRuntime(string dp1, bool bValue)
{
  bool ac, st;
  string col;
  if (bValue){
    ac = false;
    st = true;
    col = \"{33,255,52}\";
  }else{
    ac = true;
    st = false;
    col = \"{225,225,225}\";
  }
  this.enabled(ac);
  this.toggleState(st);
  this.backCol(col);
}

