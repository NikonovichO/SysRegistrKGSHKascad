"main()
{
//определяем массивы x и y для заполнения строк таблицы TABLE1
  dyn_anytype tm,cn;
  tm[1]= \"Температура , °С\";
  tm[2]= \"\";
  tm[3]=\"red\";
  cn[1]=\"Управление, °С\";
  cn[2]= \"\";
  cn[3]=\"blue\";

//заполняем строки таблицы, используя массив
  setValue(\"TABLE1\",\"updateLine\",1,\"Param\",tm,\"Value\",tm,\"TimeStemp\",tm);
  setValue(\"TABLE1\",\"updateLine\",1,\"Param\",cn,\"Value\",cn,\"TimeStemp\",cn);

  //связываем метод FillTable с DPE точки данных
  dpConnect(\"FillTable\",\"System1:\"+$dp+\"Inputs.AnalogValues.TempSupplyDiaph\",
                        \"System1:\"+$dp+\"Inputs.AnalogValues.TempReturnDiaph\");
}


void FillTable(string dpe1, float val1, string dpe2, float val2)
{
 shape table = getShape(\"TABLE1\");
 time ts1, ts2;

//записываем в поле Value переменную val1, в ту строку где поле \"Param\" = \"Давление подачи, Мпа\", 1 - число полей по которым производится поиск строки
  table.updateLine(1,\"Param\",\"Температура, °С\", \"Value\", val1);
  table.updateLine(1,\"Param\",\"Управление, %\", \"Value\", val2);

//получаем время текущего значения
  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.TempSupplyDiaph:_online.._stime\",ts1);
  table.updateLine(1,\"Param\",\"Температура подачи, °С\", \"TimeStemp\",ts1);

  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.TempReturnDiaph:_online.._stime\",ts2);
  table.updateLine(1,\"Param\",\"Температура возврата, °С\", \"TimeStemp\",ts2);

}
