"main(mapping event)
{
  int rc;
  dbConnection conn;
  dbCommand cmd;
  dbRecordset rs;
  anytype fld;
  dyn_string models;
  string cmdStr, sn, raw, model, resipe, timeS,timeE, press, diaphr, diaphr_curCicl, diaphr_ability ;

  //подключение к БД через ODBC. В приложении \"Администратор ODBC\" создается источник данных, в нашем случае KGSHVulcanisation
  rc = dbOpenConnection(\"Data Source=KGSHVulcanisation;UID=BTW\\nikonovichoa\", conn);
  Debug(\"подключение:\", rc);
  if (!rc)
  {
    //выборка данных в recordset
    cmdStr = \"SELECT serial_num, raw_tire_num, model_tire, num_recipe, quality, time_start, time_stop, num_diaphr, current_cycle, number_cycles FROM vPassport\";

    rc =  dbOpenRecordset(conn, cmdStr, rs);
    Debug(\"dbOpenRecordset\", rc);

    if (!rc)
    {
    // shape list = getShape(\"CB_Passports\");
     while (!rc && !dbEOF (rs))
      {
       dbGetField(rs, 0, sn);
       dbGetField(rs, 1, raw);
       dbGetField(rs, 2, model);
       dbGetField(rs, 3, model);

       //rc = dbSetParameter(cmd, 1, DB_PARAM_IN, 1111);
     //  list.appendItem(sn); // Добавление
       tblPassports.appendLine(\"serial_num\", sn, \"raw\", raw, \"model\", model);
       dbMoveNext(rs);
      }
     }
  }
    rc = dbCloseConnection(conn); // Соединение закрыто
}" 0
