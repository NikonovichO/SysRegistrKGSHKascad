"main()
{
//определяем массивы x и y для заполнения строк таблицы TABLE1
  dyn_anytype ts,tr,ps,pr,pf;
  ts[1]= \"Температура подачи, °С\";
  ts[2]= \"\";
  ts[3]=\"red\";
  tr[1]=\"Температура возврата, °С\";
  tr[2]= \"\";
  tr[3]=\"blue\";
  ps[1]= \"Давление подачи, Мпа\";
  ps[2]= \"\";
  ps[3]=\"red\";
  pr[1]=\"Давление возврата, МПа\";
  pr[2]= \"\";
  pr[3]=\"blue\";
  pf[1]=\"Давление формования, МПа\";
  pf[2]= \"\";
  pf[3]=\"blue\";
//заполняем строки таблицы, используя массив
  setValue(\"TABLE1\",\"updateLine\",1,\"Param\",ts,\"Value\",ts,\"TimeStemp\",ts);
  setValue(\"TABLE1\",\"updateLine\",1,\"Param\",tr,\"Value\",tr,\"TimeStemp\",tr);
  setValue(\"TABLE1\",\"updateLine\",1,\"Param\",ps,\"Value\",ps,\"TimeStemp\",ps);
  setValue(\"TABLE1\",\"updateLine\",1,\"Param\",pr,\"Value\",pr,\"TimeStemp\",pr);
  setValue(\"TABLE1\",\"updateLine\",1,\"Param\",pf,\"Value\",pf,\"TimeStemp\",pf);
//связываем метод FillTable с DPE точки данных
  dpConnect(\"FillTable\",\"System1:\"+$dp+\"Inputs.AnalogValues.TempSupplyDiaph\",
                        \"System1:\"+$dp+\"Inputs.AnalogValues.TempReturnDiaph\",
                        \"System1:\"+$dp+\"Inputs.AnalogValues.PressSupplyDiaph\",
                        \"System1:\"+$dp+\"Inputs.AnalogValues.PressReturnDiaph\",
                        \"System1:\"+$dp+\"Inputs.AnalogValues.FormingPressure\");
}

void FillTable(string dpe1, float val1, string dpe2, float val2, string dpe3, float val3, string dpe4, float val4, string dpe5, float val5)
{
 shape table = getShape(\"TABLE1\");
 time ts1, ts2, ts3, ts4, ts5;

//записываем в поле Value переменную val1, в ту строку где поле \"Param\" = \"Давление подачи, Мпа\", 1 - число полей по которым производится поиск строки
  table.updateLine(1,\"Param\",\"Температура подачи, °С\", \"Value\", val1);
  table.updateLine(1,\"Param\",\"Температура возврата, °С\", \"Value\", val2);
  Debug(\"Температура возврата, °С:\", val2);
  table.updateLine(1,\"Param\",\"Давление подачи, Мпа\", \"Value\", val3);
  table.updateLine(1,\"Param\",\"Давление возврата, МПа\", \"Value\", val4);
  table.updateLine(1,\"Param\",\"Давление формования, МПа\", \"Value\", val5);

//получаем время текущего значения
  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.TempSupplyDiaph:_online.._stime\",ts1);
  table.updateLine(1,\"Param\",\"Температура подачи, °С\", \"TimeStemp\",ts1);

  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.TempReturnDiaph:_online.._stime\",ts2);
  table.updateLine(1,\"Param\",\"Температура возврата, °С\", \"TimeStemp\",ts2);

  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.PressSupplyDiaph:_online.._stime\",ts3);
  table.updateLine(1,\"Param\",\"Давление подачи, Мпа\", \"TimeStemp\",ts3);

  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.PressSupplyDiaph:_online.._stime\",ts4);
  table.updateLine(1,\"Param\",\"Давление возврата, МПа\", \"TimeStemp\",ts4);


  dpGet(\"System1:\"+$dp+\"Inputs.AnalogValues.FormingPressure:_online.._stime\",ts5);
  table.updateLine(1,\"Param\",\"Давление формования, МПа\", \"TimeStemp\",ts5);



}
