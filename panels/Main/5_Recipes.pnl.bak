"main()
{
  int rc;
  dbConnection conn;
  dbRecordset rs;
  anytype fld1, fld2;

  // Загружаем панель навигации в модуль nav_module
  RootPanelOnModule(\"Main\\\\Recipe_sub\\\\Recipe_TaskMngr.pnl\", \"TaskMngr\", \"TaskManager\", \"\");
  RootPanelOnModule(\"Main\\\\Recipe_sub\\\\Recipe_SetValues.pnl\", \"SetValues\", \"SetValues\", \"\");
  RootPanelOnModule(\"Main\\\\Recipe_sub\\\\Recipe_SetFormValues.pnl\", \"SetFormValues\", \"SetFormValues\", \"\");

  //подключение к БД через ODBC. В приложении \"Администратор ODBC\" создается источник данных, в нашем случае KGSHVulcanisation
  rc = dbOpenConnection (\"Data Source=KGSHVulcanisation;UID=BTW\\nikonovichoa\", conn);
  Debug (\"dbOpenConnection: \", rc);
  if (!rc)
  {
    //создаем и открываем набор записей
    rc = dbOpenRecordset (conn, \"SELECT model_tire, num_recipe FROM tTires,tRecipes WHERE tTires.id_tire = tRecipes.id_tire\", rs);
    Debug(\"dbOpenRecordset: \", rc);
    // The data subset is opened
    if (!rc)
     {
       int i = 1;
       while (!rc && !dbEOF (rs)) // as long as the file end is not reached
       {
         dbGetField (rs, 0, fld1);
         dbGetField (rs, 1, fld2);
         TABLE1.appendLine(\"Model_tire\", fld1, \"Num_recipe\", fld2);
         dbMoveNext (rs); i++;
       }
       dbCloseRecordset (rs); //closes subset
     }
    dbCloseConnection (conn); //closes connection
   }
}" 0
